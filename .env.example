# Shared — matches docker-compose.yml
DATABASE_URL=postgresql://canvasly:canvasly@localhost:5432/canvasly
JWT_SECRET=dev-jwt-secret-change-me-please

# apps/web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
AUTH_TRUST_HOST=true

# Enables the dev-only email+password login used by the seed script.
# Set to "false" in any real environment.
DEV_CREDENTIALS_LOGIN=true

# Optional: Google OAuth (leave blank to disable the Google button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: SMTP for magic-link sign-in (leave blank to disable the email form)
EMAIL_SERVER=
EMAIL_FROM=no-reply@canvasly.dev

NEXT_PUBLIC_REALTIME_URL=ws://localhost:4000

# apps/realtime
REALTIME_PORT=4000
REALTIME_ORIGIN=http://localhost:3000
